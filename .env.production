# ========================================
# ENVIRONMENT: PRODUCTION (main branch)
# ========================================
# Use este arquivo como referência para configurar
# Environment Variables no Vercel Dashboard
# após validação completa das features

OPENAI_API_KEY=sk-proj-xxx-aqui-sua-chave-vercel

NODE_ENV=production
ENVIRONMENT=production

# ========================================
# FEATURES ATIVADAS PARA PRODUCTION
# ========================================
# Após testes completos e validação:
# - Modo Prática (exercícios + quiz)
# - Rota de Grading (/api/grade)
# - Cache otimizado
# - Rate limiting ativo

ENABLE_PRACTICE_MODE=true
ENABLE_GRADING=true
ENABLE_CACHE=true
ENABLE_RATE_LIMIT=true

# ========================================
# CONFIGURATION
# ========================================
PORT=3456
CACHE_TTL_MINUTES=5
RATE_LIMIT_MAX_REQUESTS=50
RATE_LIMIT_WINDOW_MINUTES=15

LOG_LEVEL=warn
