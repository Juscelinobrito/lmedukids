# ========================================
# ENVIRONMENT: STAGING (Preview URLs no Vercel)
# ========================================
# Use este arquivo como referência para configurar
# Environment Variables no Vercel Dashboard

OPENAI_API_KEY=sk-proj-xxx-aqui-sua-chave-vercel

NODE_ENV=production
ENVIRONMENT=staging

# ========================================
# FEATURES OCULTAS PARA STAGING
# ========================================
# Novas funcionalidades NÃO aparecem para usuários finais
# Apenas desenvolvedor vê em localhost

ENABLE_PRACTICE_MODE=false
ENABLE_GRADING=false
ENABLE_CACHE=true
ENABLE_RATE_LIMIT=true

# ========================================
# CONFIGURATION
# ========================================
PORT=3456
CACHE_TTL_MINUTES=5
RATE_LIMIT_MAX_REQUESTS=50
RATE_LIMIT_WINDOW_MINUTES=15

LOG_LEVEL=info
