{
  "version": 2,
  "builds": [
    {
      "src": "api/messages.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/adapt.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/messages",
      "dest": "/api/messages.js"
    },
    {
      "src": "/api/adapt",
      "dest": "/api/adapt.js"
    },

    {
      "src": "/health",
      "dest": "/api/messages.js"
    },
    {
      "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot))",
      "dest": "/frontend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
