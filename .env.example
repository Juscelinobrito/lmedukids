# ========================================
# VARIABLES DE AMBIENTE - LM EDUKIDS
# ========================================

# API KEYS
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ========================================
# FEATURE FLAGS (Controle de Funcionalidades)
# ========================================

# Ativar/Desativar modo prática com exercícios
ENABLE_PRACTICE_MODE=false

# Ativar/Desativar rota /api/grade (correção de respostas)
ENABLE_GRADING=false

# Ativar/Desativar cache inteligente
ENABLE_CACHE=true

# Ativar/Desativar rate limiting
ENABLE_RATE_LIMIT=true

# ========================================
# ENVIRONMENT (production | staging | development)
# ========================================

NODE_ENV=development
ENVIRONMENT=staging

# ========================================
# CONFIGURAÇÃO SERVIDORA
# ========================================

PORT=3456
CACHE_TTL_MINUTES=5
RATE_LIMIT_MAX_REQUESTS=50
RATE_LIMIT_WINDOW_MINUTES=15

# ========================================
# LOGGING
# ========================================

LOG_LEVEL=debug
